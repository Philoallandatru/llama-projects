# Jira Analysis 配置文件示例
# 复制此文件为 config.yaml 并填入真实配置

# Jira 配置
jira:
  server: "https://your-domain.atlassian.net"
  email: "your-email@example.com"
  token: "your-jira-api-token"
  project: "YOUR_PROJECT_KEY"  # 可选

# LLM 配置
llm:
  base_url: "http://127.0.0.1:1234/v1"  # LM Studio 默认地址
  model: "qwen3.5-4b"  # LM Studio 中加载的模型名称
  temperature: 0.1
  max_tokens: 4096
  api_key: "lm-studio"  # LM Studio 不需要真实 API key

# 索引配置
index:
  base_path: "../datasource/data/indexes"
  # 可用的索引类型
  sources:
    - jira
    - confluence
    - specs

# 本地测试模式配置
local_test:
  enabled: false  # 设为 true 使用 mock 数据
  use_mock_data: false
  mock_data_path: "./tests/fixtures"

# 日志配置
logging:
  level: "INFO"  # DEBUG, INFO, WARNING, ERROR
  format: "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
  file: "./logs/jira-analysis.log"

# 工作流配置
workflow:
  # 深度分析配置
  deep_analysis:
    max_evidence_items: 10
    similarity_threshold: 0.7

  # 批量分析配置
  batch_analysis:
    max_concurrent: 5
    timeout_seconds: 300
