# LLM Configuration
# Set USE_LOCAL_LLM=true to use local LM Studio instead of OpenAI
USE_LOCAL_LLM=true

# OpenAI Configuration (when USE_LOCAL_LLM=false)
OPENAI_API_KEY=your-openai-api-key-here
MODEL=gpt-4.1
EMBEDDING_MODEL=text-embedding-3-large

# Local LM Studio Configuration (when USE_LOCAL_LLM=true)
# LM Studio runs at http://127.0.0.1:1234
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
LM_STUDIO_MODEL=local-model
LM_STUDIO_EMBED_BASE_URL=http://127.0.0.1:1234/v1
LM_STUDIO_EMBED_MODEL=text-embedding-3-large
REQUEST_TIMEOUT=300

# Local Data Source
LOCAL_DATA_DIR=./data

# Jira Configuration (optional)
JIRA_ENABLED=false
JIRA_SERVER_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_TOKEN=your_jira_api_token
JIRA_JQL=project = PROJ ORDER BY updated DESC

# Confluence Configuration (optional)
CONFLUENCE_ENABLED=false
CONFLUENCE_BASE_URL=https://your-domain.atlassian.net/wiki
CONFLUENCE_EMAIL=your-email@example.com
CONFLUENCE_TOKEN=your_confluence_api_token
CONFLUENCE_SPACE_KEY=SPACE
CONFLUENCE_CQL=
